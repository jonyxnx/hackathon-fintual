# Which LLM provider to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Notion docs sync
NOTION_TOKEN=
NOTION_PAGE_ID=

# Optional: GitHub token raises rate limits and enables private repos
GITHUB_TOKEN=

# Max concurrent LLM doc generations in CI/CLI (default: 4)
KITDOC_DOC_CONCURRENCY=4
